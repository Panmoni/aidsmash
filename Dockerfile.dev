# Dockerfile para entorno de desarrollo de AidSmash
# Incluye Rust, Solana CLI, Anchor CLI y Node.js

FROM ubuntu:22.04

# Evitar prompts interactivos durante instalación
ENV DEBIAN_FRONTEND=noninteractive

# Instalar dependencias del sistema
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    build-essential \
    pkg-config \
    libssl-dev \
    libudev-dev \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Instalar Node.js 18.x
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g pnpm yarn

# Crear usuario no-root para desarrollo
RUN useradd -m -s /bin/bash solana && \
    echo "solana ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Cambiar a usuario solana
USER solana
WORKDIR /home/solana

# Instalar Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/home/solana/.cargo/bin:${PATH}"

# Configurar Rust para usar versión estable
RUN rustup default stable && \
    rustup component add rustfmt clippy

# Instalar Solana CLI (v1.18.x - versión estable compatible con Anchor)
RUN sh -c "$(curl -sSfL https://release.solana.com/v1.18.26/install)"
ENV PATH="/home/solana/.local/share/solana/install/active_release/bin:${PATH}"

# Instalar Anchor CLI (v0.30.1)
RUN cargo install --git https://github.com/coral-xyz/anchor avm --locked --force
RUN avm install 0.30.1 && avm use 0.30.1
ENV PATH="/home/solana/.avm/bin:${PATH}"

# Configurar Solana para usar devnet por defecto
RUN solana config set --url devnet

# Crear directorio de trabajo para el proyecto
WORKDIR /workspace

# Exponer puertos útiles
# 8899: Solana local validator
# 5173: Vite dev server (frontend)
# 8080: Anchor test validator
EXPOSE 8899 5173 8080

# Comando por defecto
CMD ["/bin/bash"]